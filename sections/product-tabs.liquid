{%- liquid
  assign product = closest.product | default: product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign tab_label_description = section.settings.label_description | default: 'Description'
  assign tab_label_delivery = section.settings.label_delivery | default: 'Delivery & Returns'

  assign description_content = section.settings.description_override
  if description_content == blank
    assign description_content = product.description
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--page-width color-{{ section.settings.color_scheme }}">
  <product-tabs
    class="product-tabs"
    id="product-tabs-{{ section.id }}"
    style="--product-tabs-radius: {{ section.settings.corner_radius }}px;"
  >
    <div
      class="product-tabs__list"
      role="tablist"
      aria-label="{{ product.title | default: 'Product' | escape }} information"
    >
      <button
        type="button"
        class="product-tabs__tab"
        role="tab"
        id="product-tabs-{{ section.id }}-tab-description"
        aria-controls="product-tabs-{{ section.id }}-panel-description"
        aria-selected="true"
        tabindex="0"
      >
        {{ tab_label_description | escape }}
      </button>
      <button
        type="button"
        class="product-tabs__tab"
        role="tab"
        id="product-tabs-{{ section.id }}-tab-delivery"
        aria-controls="product-tabs-{{ section.id }}-panel-delivery"
        aria-selected="false"
        tabindex="-1"
      >
        {{ tab_label_delivery | escape }}
      </button>
    </div>

    <div
      class="product-tabs__panel"
      role="tabpanel"
      id="product-tabs-{{ section.id }}-panel-description"
      aria-labelledby="product-tabs-{{ section.id }}-tab-description"
      tabindex="0"
    >
      <div class="product-tabs__rte">
        {{ description_content }}
      </div>
    </div>

    <div
      class="product-tabs__panel"
      role="tabpanel"
      id="product-tabs-{{ section.id }}-panel-delivery"
      aria-labelledby="product-tabs-{{ section.id }}-tab-delivery"
      tabindex="0"
      hidden
    >
      <div class="product-tabs__rte">
        {{ section.settings.delivery_content }}
      </div>
    </div>
  </product-tabs>
</div>

{% stylesheet %}
  .product-tabs {
    display: block;
    max-width: 62rem;
    margin-inline: auto;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 10%, transparent);
    border-radius: var(--product-tabs-radius, 18px);
    background: var(--color-background);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 12px 32px -16px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }

  .product-tabs__list {
    display: flex;
    gap: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    background: color-mix(in srgb, var(--color-foreground) 2%, transparent);
  }

  .product-tabs__tab {
    flex: 1 1 auto;
    appearance: none;
    border: 0;
    background: transparent;
    cursor: pointer;
    padding: 1.25rem 1.5rem;
    font: inherit;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-foreground) 55%, transparent);
    position: relative;
    text-align: center;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .product-tabs__tab + .product-tabs__tab {
    border-left: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
  }

  .product-tabs__tab::after {
    content: "";
    position: absolute;
    left: 1.25rem;
    right: 1.25rem;
    bottom: -1px;
    height: 2px;
    border-radius: 2px;
    background: var(--color-foreground);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s ease;
  }

  .product-tabs__tab:hover {
    color: var(--color-foreground);
  }

  .product-tabs__tab[aria-selected="true"] {
    color: var(--color-foreground);
    font-weight: 600;
    background: var(--color-background);
  }

  .product-tabs__tab[aria-selected="true"]::after {
    transform: scaleX(1);
  }

  .product-tabs__tab:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: -3px;
    border-radius: 4px;
  }

  .product-tabs__panel {
    padding: 1.75rem 1.75rem 2rem;
    animation: product-tabs-fade 0.3s ease;
  }

  .product-tabs__panel[hidden] {
    display: none;
  }

  .product-tabs__rte {
    color: color-mix(in srgb, var(--color-foreground) 80%, transparent);
    line-height: 1.65;
    font-size: 1rem;
  }

  .product-tabs__rte > :first-child {
    margin-top: 0;
  }

  .product-tabs__rte > :last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 480px) {
    .product-tabs__tab {
      padding: 1rem 0.75rem;
      font-size: 0.9375rem;
    }

    .product-tabs__panel {
      padding: 1.25rem 1.25rem 1.5rem;
    }
  }

  @keyframes product-tabs-fade {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-tabs__tab::after,
    .product-tabs__panel {
      transition: none;
      animation: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  class ProductTabs extends HTMLElement {
    connectedCallback() {
      this.tabs = Array.from(this.querySelectorAll('[role="tab"]'));
      this.panels = Array.from(this.querySelectorAll('[role="tabpanel"]'));

      this.tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => this.select(index));
        tab.addEventListener('keydown', (event) => this.onKeydown(event, index));
      });
    }

    select(index) {
      this.tabs.forEach((tab, i) => {
        const selected = i === index;
        tab.setAttribute('aria-selected', selected ? 'true' : 'false');
        tab.setAttribute('tabindex', selected ? '0' : '-1');
        this.panels[i].hidden = !selected;
      });
    }

    onKeydown(event, index) {
      const last = this.tabs.length - 1;
      let next = null;

      if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
        next = index === last ? 0 : index + 1;
      } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
        next = index === 0 ? last : index - 1;
      } else if (event.key === 'Home') {
        next = 0;
      } else if (event.key === 'End') {
        next = last;
      }

      if (next !== null) {
        event.preventDefault();
        this.select(next);
        this.tabs[next].focus();
      }
    }
  }

  if (!customElements.get('product-tabs')) {
    customElements.define('product-tabs', ProductTabs);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Product tabs",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "t:settings.border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Description tab"
    },
    {
      "type": "text",
      "id": "label_description",
      "label": "Tab label",
      "default": "Description"
    },
    {
      "type": "richtext",
      "id": "description_override",
      "label": "Description content",
      "info": "Leave empty to use the product's own description."
    },
    {
      "type": "header",
      "content": "Delivery & Returns tab"
    },
    {
      "type": "text",
      "id": "label_delivery",
      "label": "Tab label",
      "default": "Delivery & Returns"
    },
    {
      "type": "richtext",
      "id": "delivery_content",
      "label": "Delivery & Returns content",
      "default": "<p>Free worldwide shipping on every order. Most orders arrive within 5–7 business days.</p><p>Not the right fit? Return it within 30 days for a full refund — no questions asked.</p>"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Product tabs",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
