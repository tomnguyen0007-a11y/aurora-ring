.aurs-finput,.aurs-ftextarea{width:100%;background:#080809;border:1px solid #1a1a22;border-radius:9px;padding:12px 15px;color:#e0e0ee;font-size:13px;font-family:inherit;outline:none;box-sizing:border-box;transition:border-color .2s;}
