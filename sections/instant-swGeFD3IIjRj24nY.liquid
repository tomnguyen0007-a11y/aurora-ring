    <button class="aurs-fb on" onclick="aursFilter(0,this)">All</button>
    <button class="aurs-fb" onclick="aursFilter(5,this)">5 ★</button>
    <button class="aurs-fb" onclick="aursFilter(4,this)">4 ★</button>
    <button class="aurs-fb" onclick="aursFilter(3,this)">3 ★</button>
    <div class="aurs-sort-sep">
      <span class="aurs-flbl">SORT:</span>
      <button class="aurs-fb on" id="srt-h" onclick="aursSort('helpful',this)">Most Helpful</button>
      <button class="aurs-fb" id="srt-r" onclick="aursSort('recent',this)">Most Recent</button>
    </div>
  </div>

  <!-- Dynamic grid -->
  <div class="aurs-grid" id="aurs-grid"></div>
  <div class="aurs-nores" id="aurs-nores" style="display:none;">No reviews match this filter.</div>

  <!-- ── Review submission form (Shopify contact form) ── -->
  <div id="aurs-form-section" class="aurs-form-section">
    <h3 class="aurs-form-title">Share your experience</h3>
    <p class="aurs-form-sub">Your review will appear on this page after a quick check.</p>

    {% form 'contact' %}
      <input type="hidden" name="contact[tags]" value="aurora-review,pending">
      <input type="hidden" name="contact[subject]" value="New AURORA Ring Review">

      <div class="aurs-fgroup">
        <label class="aurs-flabel">Your Rating</label>
        <div class="aurs-star-row" id="aurs-spicker">
          <span class="aurs-sp" data-v="1">★</span>
          <span class="aurs-sp" data-v="2">★</span>
          <span class="aurs-sp" data-v="3">★</span>
          <span class="aurs-sp" data-v="4">★</span>
          <span class="aurs-sp" data-v="5">★</span>
        </div>
        <input type="hidden" name="contact[rating]" id="aurs-rat-val" value="">
        <div class="aurs-ferr" id="err-rat">Please select a star rating.</div>
      </div>

      <div class="aurs-fgroup">
        <label class="aurs-flabel">Your Name</label>
        <input class="aurs-finput" name="contact[name]" type="text" placeholder="e.g. Jordan M." required>
        <div class="aurs-ferr" id="err-name">Name is required.</div>
      </div>

      <div class="aurs-fgroup">
        <label class="aurs-flabel">Review Title</label>
        <input class="aurs-finput" name="contact[review_title]" type="text" placeholder="Summarise your experience in one line" required>
      </div>

      <div class="aurs-fgroup">
        <label class="aurs-flabel">Your Review</label>
        <textarea class="aurs-finput aurs-ftextarea" name="contact[body]" rows="5"
          placeholder="What changed after wearing it? How did it affect your sleep, HRV, or daily routine?" required></textarea>
      </div>

      <div class="aurs-fgroup">
        <label class="aurs-flabel">Email (not published)</label>
        <input class="aurs-finput" name="contact[email]" type="email" placeholder="your@email.com" required>
      </div>

      <input type="submit" value="SUBMIT REVIEW" class="aurs-btn-grad" style="width:100%;cursor:pointer;border:none;padding:15px;border-radius:12px;font-size:12px;letter-spacing:.1em;margin-top:4px;">
    {% endform %}
  </div>

</div>
</div>

<script>
(function(){
/* ── Seed reviews ── */
var SEED=[
  {id:'s-1',name:'Jennifer M.',r:5,v:true,date:'2026-05-18',dl:'May 2026',helpful:42,title:'Accurate, comfortable, no subscription',body:'Waterproof, durable and stylish. Tracks heart rate, sleep and my cycle. Honestly surprised how accurate the sleep data is — and no monthly fee. Wear it every day.'},
  {id:'s-2',name:'David K.',r:5,v:true,date:'2026-05-11',dl:'May 2026',helpful:38,title:'Battery genuinely lasts a week',body:'Charge once and forget about it. Waterproof so I never take it off. The app is easy to read every morning. Incredible value for the money.'},
  {id:'s-3',name:'Rachel T.',r:5,v:true,date:'2026-05-04',dl:'May 2026',helpful:31,title:'Looks high-end, true to size',body:'Sleek and premium-looking. Ordered a size 7 and it fits perfectly. Lasts for days on a charge and feels great to wear all day. Highly recommend.'},
  {id:'s-4',name:'Carlos R.',r:5,v:true,date:'2026-04-27',dl:'Apr 2026',helpful:29,title:'Data matches my other trackers',body:'Measures exactly. The app reports very extensively and I compared it against two other health trackers — all very close. Worth every cent.'},
  {id:'s-5',name:'Linda W.',r:5,v:true,date:'2026-04-21',dl:'Apr 2026',helpful:24,title:'Bought it for sleep — exactly what I needed',body:'Battery lasts the whole week. Comfortable enough to wear through the night without noticing it. The sleep breakdown is genuinely useful.'},
  {id:'s-6',name:'Marcus O.',r:5,v:true,date:'2026-04-14',dl:'Apr 2026',helpful:22,title:'Real insights every morning',body:'The brand clearly specialises in this tech and it shows. Very reasonable price for the feature set. The Aurora app gives me real health insights daily.'},
  {id:'s-7',name:'Sophie A.',r:5,v:true,date:'2026-04-06',dl:'Apr 2026',helpful:19,title:'Perfect for sleep without a watch',body:'I find smartwatches cumbersome at night but still wanted to track activity — this is the perfect solution. Undeniably cool too.'},
  {id:'s-8',name:'Aisha P.',r:5,v:true,date:'2026-03-30',dl:'Mar 2026',helpful:17,title:'No subscription is a massive win',body:'Heart rate and step accuracy are surprisingly good. Comfortable all day. I get all the data without a monthly bill. 10/10 would buy again.'},
  {id:'s-9',name:'Kevin L.',r:5,v:true,date:'2026-03-22',dl:'Mar 2026',helpful:15,title:'Plenty of detailed data',body:'With the Aurora app it tracks heart rate, oxygen, stress, sleep and HRV. Recommended for anyone who wants detailed numbers, not just a step count.'},
  {id:'s-10',name:'Natalie S.',r:4,v:true,date:'2026-03-15',dl:'Mar 2026',helpful:12,title:'Excellent — wish it synced to Apple Health',body:'The sleep and HRV data has been eye-opening. Four stars only because I wish it synced with Apple Health, but for standalone use it is excellent.'},
  {id:'s-11',name:'Bruno F.',r:5,v:true,date:'2026-03-08',dl:'Mar 2026',helpful:11,title:'Unbeatable pricing',body:'Genuine health tracking for the cost of a nice lunch. No other brand offers this at this price. The week-long battery is the real standout.'},
  {id:'s-12',name:'Hannah V.',r:5,v:true,date:'2026-02-28',dl:'Feb 2026',helpful:9,title:'Cycle tracking is a game changer',body:'The temperature trend and cycle predictions have been spot on. Discreet, comfortable and the app explains what the numbers mean. Love it.'}
];

var state={reviews:[],fStar:0,sort:'helpful',pickedR:0,voted:{}};
var TARGET=2843;
/* Realistic verified-purchase distribution (scales the summary bars) */
var DIST={5:2510,4:248,3:61,2:18,1:6};

/* animate counter */
function countUp(el,target){
  var s=0,step=Math.ceil(target/80),t=setInterval(function(){
    s=Math.min(s+step,target);
    el.textContent=s.toLocaleString()+'+';
    if(s>=target)clearInterval(t);
  },18);
}

function load(){
  try{
    var u=JSON.parse(localStorage.getItem('aurs-reviews')||'[]');
    state.reviews=SEED.concat(u);
  }catch(e){state.reviews=SEED.slice();}
  // Add user reviews to counter
  var total=TARGET+state.reviews.filter(function(r){return r.id.indexOf('u-')===0;}).length;
  var el=document.getElementById('aurs-counter');
  if(el) countUp(el,total);
  render();
}

function save(){
  try{
    var u=state.reviews.filter(function(r){return r.id.indexOf('u-')===0;});
    localStorage.setItem('aurs-reviews',JSON.stringify(u));
  }catch(e){}
}

function starsHtml(n,sz){
  var s='';sz=sz||11;
  for(var i=1;i<=5;i++)s+='<span style="color:'+(i<=n?'#f5b400':'#1a1a22')+';font-size:'+sz+'px;">&#9733;</span>';
  return s;
}

function renderBars(){
  /* Base on the verified distribution, then fold in any local user reviews */
  var stats={5:DIST[5],4:DIST[4],3:DIST[3],2:DIST[2],1:DIST[1]};
  state.reviews.forEach(function(r){
    if(r.id.indexOf('u-')===0 && stats[r.r]!=null) stats[r.r]++;
  });
  var total=0,weighted=0;
  [5,4,3,2,1].forEach(function(s){ total+=stats[s]; weighted+=s*stats[s]; });
  var avg=total?weighted/total:0;
  document.getElementById('aurs-avg').textContent=avg.toFixed(1);
  document.getElementById('aurs-avg-top').textContent=avg.toFixed(1);
  document.getElementById('aurs-total').textContent='Based on '+total.toLocaleString()+' verified reviews';
  var b='';
  [5,4,3,2,1].forEach(function(s){
    var n=stats[s]||0;
    var pct=total?Math.round(n/total*100):0;
    b+='<div class="aurs-bar-row"><span class="aurs-bar-lbl">'+s+'</span>'
      +'<div class="aurs-bar-track"><div class="aurs-bar-fill" style="width:'+pct+'%"></div></div>'
      +'<span class="aurs-bar-n">'+pct+'%</span></div>';
  });
  document.getElementById('aurs-bars').innerHTML=b;
}

function renderGrid(){
  var list=state.reviews.slice();
  if(state.fStar)list=list.filter(function(r){return r.r===state.fStar;});
  if(state.sort==='helpful')list.sort(function(a,b){return b.helpful-a.helpful;});
  else list.sort(function(a,b){return a.date<b.date?1:-1;});
  var grid=document.getElementById('aurs-grid');
  var nores=document.getElementById('aurs-nores');
  if(!list.length){grid.innerHTML='';nores.style.display='block';return;}
  nores.style.display='none';
  grid.innerHTML=list.map(function(r){
    var vt=state.voted[r.id];
    return '<div class="aurs-card">'
      +'<div class="aurs-card-top"><div>'
        +'<div class="aurs-cname">'+r.name+'</div>'
        +(r.v?'<div class="aurs-cver">&#10003; VERIFIED BUYER</div>':'')
      +'</div><span class="aurs-cdate">'+r.dl+'</span></div>'
      +'<div class="aurs-cstars">'+starsHtml(r.r)+'</div>'
      +'<p class="aurs-ctitle">'+r.title+'</p>'
      +'<p class="aurs-cbody">'+r.body+'</p>'
      +'<div class="aurs-helpful"><span class="aurs-hlbl">Helpful?</span>'
      +'<button class="aurs-hbtn'+(vt?' voted':'')+'"'+(vt?' disabled':'')+' onclick="aursHelpful(\''+r.id+'\')">'
      +'&#128077; '+r.helpful+'</button></div></div>';
  }).join('');
}

function render(){renderBars();renderGrid();}

window.aursFilter=function(s,btn){
  state.fStar=s;
  document.querySelectorAll('.aurs-fb').forEach(function(b){
    if(b.id!=='srt-h'&&b.id!=='srt-r')b.classList.remove('on');
  });
  btn.classList.add('on');
  renderGrid();
};
window.aursSort=function(by,btn){
  state.sort=by;
  document.getElementById('srt-h').classList.toggle('on',by==='helpful');
  document.getElementById('srt-r').classList.toggle('on',by==='recent');
  renderGrid();
};
window.aursHelpful=function(id){
  if(state.voted[id])return;
  state.voted[id]=true;
  var r=state.reviews.find(function(x){return x.id===id;});
  if(r)r.helpful++;
  save();renderGrid();
};
window.aursOpenForm=function(){
  var f=document.getElementById('aurs-form-section');
  f.classList.add('open');
  f.scrollIntoView({behavior:'smooth',block:'start'});
};
window.aursScrollLeft=function(){
  var t=document.getElementById('aurs-vscroll');
  t.scrollBy({left:-310,behavior:'smooth'});
};
window.aursScrollRight=function(){
  var t=document.getElementById('aurs-vscroll');
  t.scrollBy({left:310,behavior:'smooth'});
};

/* Star picker */
document.addEventListener('DOMContentLoaded',function(){
  var sp=document.querySelectorAll('.aurs-sp');
  sp.forEach(function(s){
    s.addEventListener('click',function(){
      state.pickedR=parseInt(s.getAttribute('data-v'));
      var inp=document.getElementById('aurs-rat-val');
      if(inp)inp.value=state.pickedR;
      sp.forEach(function(x){x.classList.toggle('on',parseInt(x.getAttribute('data-v'))<=state.pickedR);});
    });
    s.addEventListener('mouseover',function(){
      var v=parseInt(s.getAttribute('data-v'));
      sp.forEach(function(x){x.classList.toggle('on',parseInt(x.getAttribute('data-v'))<=v);});
    });
    s.addEventListener('mouseout',function(){
      sp.forEach(function(x){x.classList.toggle('on',parseInt(x.getAttribute('data-v'))<=state.pickedR);});
    });
  });

  /* Show thank-you if Shopify redirected back after form submit */
  if(window.location.search.indexOf('contact_posted=true')>-1){
    var f=document.getElementById('aurs-form-section');
    if(f){
      f.classList.add('open');
      f.innerHTML='<div style="text-align:center;padding:56px 0;">'
        +'<div style="font-size:44px;margin-bottom:16px;">&#10003;</div>'
        +'<h3 style="font-size:22px;font-weight:300;color:#fff;margin:0 0 8px;">Thank you!</h3>'
        +'<p style="font-size:13px;color:#444;">Your review has been received and will appear shortly.</p>'
        +'</div>';
      f.scrollIntoView({behavior:'smooth'});
    }
  }

  load();
});
})();
</script>


