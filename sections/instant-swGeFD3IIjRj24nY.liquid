<script>
(function(){
  var sec=document.getElementById('aued');if(!sec)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function countStat(){
    var n=sec.querySelector('.aued-stat-num');if(!n)return;
    var t=parseInt(n.getAttribute('data-count')||'7',10);
    if(reduce){n.textContent=t;return;}
    var c=0,iv=setInterval(function(){c++;n.textContent=c;if(c>=t)clearInterval(iv);},90);
  }
  var els=[].slice.call(sec.querySelectorAll('.aued-intro, .aued-panel, .aued-shot'));
  if(!('IntersectionObserver' in window)){countStat();return;}
  var io=new IntersectionObserver(function(es){
    es.forEach(function(e){
      if(e.isIntersecting){
        e.target.classList.add('in');
        if(e.target.classList.contains('aued-panel--stat'))countStat();
        io.unobserve(e.target);
      }
    });
  },{threshold:.14,rootMargin:'0px 0px -8% 0px'});
  els.forEach(function(el){el.classList.add('aued-reveal');io.observe(el);});
})();
</script>


