<!-- ═══════════════════════════════════════════
     AURORA — EDITORIAL "FEELING" SECTION
════════════════════════════════════════════ -->
{%- liquid
  assign aued_p = all_products['aurora-ring']
  assign aued_img = aued_p.featured_image
-%}
<style>
/* Editorial typography elevation — serif display headlines across the homepage
   (typeface only; size/color/line-height untouched, so layout is unaffected) */
.ix82zWXwjPWs8CNpP h1,
.ix82zWXwjPWs8CNpP h2:not(.aued-title){
  font-family:'Instrument Serif', Georgia, serif !important;
  font-weight:400 !important;
  font-style:normal !important;
  letter-spacing:-.015em !important;
}

/* ── Editorial "feeling" section ── */
#aued{position:relative;background:#0a0a0c;padding:120px 24px;border-top:1px solid #141418;overflow:hidden;font-family:'Inter',sans-serif;}
#aued::before{content:"";position:absolute;left:-10%;right:-10%;bottom:-30%;height:560px;pointer-events:none;z-index:0;
  background:radial-gradient(40% 60% at 20% 100%,rgba(0,229,200,.10),transparent 70%),radial-gradient(46% 64% at 82% 92%,rgba(124,58,237,.13),transparent 70%),radial-gradient(40% 50% at 50% 100%,rgba(224,17,95,.07),transparent 72%);filter:blur(30px);animation:aued-drift 22s ease-in-out infinite alternate;}
@keyframes aued-drift{0%{transform:translate3d(-2%,0,0)}100%{transform:translate3d(3%,-2%,0)}}
.aued-wrap{position:relative;z-index:1;max-width:1120px;margin:0 auto;}

.aued-intro{max-width:700px;margin:0 0 56px;transition:opacity .8s cubic-bezier(.16,1,.3,1),translate .8s cubic-bezier(.16,1,.3,1);}
.aued-eyebrow{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.28em;color:#00e5c8;margin-bottom:20px;}
.aued-title{margin:0 0 18px;font-family:'Inter',sans-serif;font-size:clamp(34px,5.2vw,68px);line-height:1.05;font-weight:300;color:#f4f4f8;letter-spacing:-.02em;}
.aued-title em{font-family:'Instrument Serif',Georgia,serif;font-style:italic;font-weight:400;
  background:linear-gradient(100deg,#ffffff 0%,#9fe9df 28%,#b39df6 58%,#ffffff 88%);background-size:220% 100%;
  -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:aued-shine 6s linear infinite;}
@keyframes aued-shine{to{background-position:-220% 0;}}
.aued-sub{margin:0;font-size:clamp(15px,1.6vw,18px);line-height:1.6;color:#8a8a9a;font-weight:300;max-width:540px;}

.aued-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
@media(max-width:880px){.aued-grid{grid-template-columns:1fr;}}

/* Oura-style product gallery (auto-pulled from product media) */
.aued-gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;}
.aued-shot{position:relative;margin:0;border-radius:18px;overflow:hidden;aspect-ratio:4/3;background:#0d0d12;border:1px solid rgba(255,255,255,.08);box-shadow:0 30px 60px -30px rgba(0,0,0,.9);
  transition:transform .5s cubic-bezier(.16,1,.3,1),translate .8s cubic-bezier(.16,1,.3,1),opacity .8s cubic-bezier(.16,1,.3,1),box-shadow .4s,border-color .4s;}
.aued-shot::after{content:"";position:absolute;inset:0;border-radius:inherit;pointer-events:none;box-shadow:inset 0 0 70px rgba(0,0,0,.14);}
.aued-shot img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.16,1,.3,1);}
.aued-shot:hover{transform:translateY(-6px);border-color:rgba(0,229,200,.30);box-shadow:0 40px 80px -28px rgba(0,0,0,.95),0 0 50px -14px rgba(124,58,237,.30);}
.aued-shot:hover img{transform:scale(1.06);}
@media (prefers-reduced-motion: reduce){.aued-shot,.aued-shot img{transition:none !important;}.aued-shot{opacity:1 !important;translate:0 0 !important;}}
.aued-panel{position:relative;border-radius:20px;padding:24px;min-height:380px;display:flex;flex-direction:column;justify-content:space-between;
  background:linear-gradient(158deg,rgba(255,255,255,.055),rgba(255,255,255,.012));
  -webkit-backdrop-filter:blur(22px) saturate(150%);backdrop-filter:blur(22px) saturate(150%);
  border:1px solid rgba(255,255,255,.08);box-shadow:inset 0 1px 0 rgba(255,255,255,.07),0 30px 60px -30px rgba(0,0,0,.9);overflow:hidden;
  transition:transform .5s cubic-bezier(.16,1,.3,1),translate .8s cubic-bezier(.16,1,.3,1),opacity .8s cubic-bezier(.16,1,.3,1),border-color .4s,box-shadow .4s;}
.aued-panel:nth-child(2){transition-delay:.08s}
.aued-panel:nth-child(3){transition-delay:.16s}
.aued-panel:hover{transform:translateY(-6px);border-color:rgba(0,229,200,.32);box-shadow:inset 0 1px 0 rgba(255,255,255,.10),0 40px 80px -28px rgba(0,0,0,.95),0 0 50px -12px rgba(124,58,237,.30);}

.aued-cap{display:flex;flex-direction:column;gap:3px;margin-top:20px;}
.aued-cap-k{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.2em;color:#5a5a70;text-transform:uppercase;}
.aued-cap-v{font-size:13px;color:#c9c9d6;font-weight:300;}
.aued-cap-v em{font-style:normal;color:#00e5c8;}

/* Panel 1 — product render */
.aued-panel--media .aued-media{position:relative;flex:1;display:flex;align-items:center;justify-content:center;border-radius:14px;overflow:hidden;
  background:radial-gradient(60% 60% at 50% 40%,rgba(124,58,237,.22),transparent 70%),#0d0d12;}
.aued-panel--media .aued-media::after{content:"";position:absolute;inset:0;background:radial-gradient(50% 40% at 50% 112%,rgba(0,229,200,.18),transparent 70%);}
.aued-panel--media img{position:relative;z-index:1;max-width:88%;max-height:290px;object-fit:contain;filter:drop-shadow(0 30px 50px rgba(0,0,0,.6));transition:transform .6s cubic-bezier(.16,1,.3,1);}
.aued-panel--media:hover img{transform:scale(1.05) rotate(-2deg);}
.aued-media-fallback{font-family:'Instrument Serif',serif;font-size:48px;color:#2a2a38;}

/* Panel 2 — live data glass card */
.aued-panel--data{background:linear-gradient(158deg,rgba(0,229,200,.06),rgba(124,58,237,.05));}
.aued-live{display:inline-flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;color:#9fe9df;}
.aued-live-dot{width:7px;height:7px;border-radius:50%;background:#00e5c8;box-shadow:0 0 10px #00e5c8;animation:aued-pulse 2.2s ease-in-out infinite;}
@keyframes aued-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.aued-metric{display:flex;flex-direction:column;gap:13px;margin:6px 0;}
.aued-metric-row{display:flex;justify-content:space-between;align-items:baseline;font-size:13px;color:#8a8a9a;border-bottom:1px solid rgba(255,255,255,.06);padding-bottom:12px;}
.aued-metric-row b{font-size:24px;font-weight:300;color:#fff;}
.aued-metric-row small{font-size:12px;color:#8a8a9a;font-weight:300;}
.aued-metric-row em{font-style:normal;font-size:12px;color:#00e5c8;margin-left:6px;}
.aued-spark{display:flex;align-items:flex-end;gap:5px;height:32px;margin:2px 0;}
.aued-spark i{flex:1;background:linear-gradient(180deg,#00e5c8,#7c3aed);border-radius:2px;opacity:.85;transform-origin:bottom;animation:aued-bar 1.8s ease-in-out infinite;}
.aued-spark i:nth-child(1){height:40%;animation-delay:0s}.aued-spark i:nth-child(2){height:70%;animation-delay:.1s}.aued-spark i:nth-child(3){height:50%;animation-delay:.2s}.aued-spark i:nth-child(4){height:92%;animation-delay:.3s}.aued-spark i:nth-child(5){height:60%;animation-delay:.4s}.aued-spark i:nth-child(6){height:80%;animation-delay:.5s}.aued-spark i:nth-child(7){height:45%;animation-delay:.6s}
@keyframes aued-bar{0%,100%{transform:scaleY(.85)}50%{transform:scaleY(1.12)}}

/* Panel 3 — typographic stat */
.aued-panel--stat{background:linear-gradient(158deg,rgba(255,255,255,.06),rgba(255,255,255,.012));}
.aued-stat{display:flex;align-items:baseline;gap:10px;}
.aued-stat-num{font-family:'Instrument Serif',Georgia,serif;font-size:108px;line-height:.78;color:#fff;font-weight:400;}
.aued-stat-unit{font-size:20px;color:#8a8a9a;font-weight:300;}
.aued-stat-meta{display:flex;flex-direction:column;gap:8px;margin-top:18px;}
.aued-stat-meta span{font-size:13px;color:#9a9aaa;font-weight:300;line-height:1.45;}
.aued-stat-meta span:first-child{color:#d8d8e8;}

/* reveal */
.aued-reveal{opacity:0;translate:0 26px;}
.aued-reveal.in{opacity:1;translate:0 0;}

@media (prefers-reduced-motion: reduce){
  #aued::before,.aued-title em,.aued-live-dot,.aued-spark i{animation:none !important;}
  .aued-title em{-webkit-text-fill-color:#b39df6;}
  .aued-reveal,.aued-reveal.in{opacity:1 !important;translate:0 0 !important;}
  .aued-panel,.aued-panel--media img,.aued-intro{transition:none !important;}
}
</style>

<section id="aued" aria-label="Why AURORA feels different">
  <div class="aued-wrap">
    <div class="aued-intro">
      <span class="aued-eyebrow">THE DIFFERENCE</span>
      <h2 class="aued-title">Engineered to vanish.<br><em>Designed to be felt.</em></h2>
      <p class="aued-sub">Titanium thin enough to forget you're wearing it. Intelligence deep enough to change how you live.</p>
    </div>

    {%- assign aued_imgs = aued_p.images -%}
