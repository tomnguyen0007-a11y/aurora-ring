<style>
/* ── Layout ── */
#aurs{background:#0c0c10;padding:96px 24px 80px;border-top:1px solid #141418;display:none;/* hidden until Judge.me real reviews — remove display:none to re-show */}
.aurs-wrap{max-width:1120px;margin:0 auto;}

/* ── Hero bar ── */
.aurs-hero{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:32px;margin-bottom:64px;}
.aurs-headline h2{font-size:clamp(28px,4vw,48px);font-weight:300;color:#fff;margin:0 0 8px;line-height:1.1;}
.aurs-headline p{font-size:14px;color:#555;margin:0;}
.aurs-badges{display:flex;gap:24px;flex-wrap:wrap;}
.aurs-badge{text-align:center;}
.aurs-badge-num{font-size:32px;font-weight:300;color:#fff;line-height:1;background:linear-gradient(90deg,#00e5c8,#7c3aed,#e0115f);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.aurs-badge-lbl{font-size:10px;letter-spacing:.14em;color:#666;margin-top:4px;text-transform:uppercase;}

/* ── Summary row ── */
.aurs-summary{display:flex;align-items:flex-start;gap:48px;margin-bottom:48px;padding-bottom:40px;border-bottom:1px solid #141418;flex-wrap:wrap;}
.aurs-avg-block{text-align:center;min-width:120px;}
.aurs-avg-num{font-size:64px;font-weight:300;color:#fff;line-height:1;}
.aurs-avg-stars{color:#f5b400;font-size:18px;letter-spacing:2px;margin:4px 0;}
.aurs-avg-sub{font-size:11px;color:#666;}
.aurs-bars{flex:1;min-width:220px;}
.aurs-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.aurs-bar-lbl{font-size:11px;color:#6a6a80;width:20px;text-align:right;}
.aurs-bar-track{flex:1;height:5px;background:#1a1a22;border-radius:3px;overflow:hidden;}
.aurs-bar-fill{height:100%;background:#f5b400;border-radius:3px;transition:width .7s ease;}
.aurs-bar-n{font-size:11px;color:#2e2e3e;width:18px;}
.aurs-write-cta-inline{display:flex;flex-direction:column;gap:10px;justify-content:center;}
.aurs-btn-grad{display:inline-block;padding:13px 28px;border-radius:999px;border:none;background:linear-gradient(135deg,#00e5c8,#7c3aed,#e0115f);background-size:300% 300%;animation:aurs-grad 5s ease infinite;color:#fff;font-size:12px;letter-spacing:.1em;font-family:inherit;cursor:pointer;text-transform:uppercase;transition:opacity .2s,transform .15s;text-align:center;text-decoration:none;}
.aurs-btn-grad:hover{opacity:.88;transform:scale(1.02);}
.aurs-btn-ghost{display:inline-block;padding:12px 28px;border-radius:999px;border:1px solid #1e1e1e;background:transparent;color:#555;font-size:12px;letter-spacing:.1em;font-family:inherit;cursor:pointer;text-transform:uppercase;transition:all .2s;text-align:center;}
.aurs-btn-ghost:hover{border-color:#00e5c8;color:#00e5c8;}
@keyframes aurs-grad{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}

/* ── Filters ── */
.aurs-filter-row{display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;align-items:center;}
.aurs-flbl{font-size:10px;color:#555;letter-spacing:.12em;}
.aurs-fb{padding:6px 14px;border-radius:999px;border:1px solid #222232;background:transparent;color:#666;font-size:11px;cursor:pointer;font-family:inherit;transition:all .18s;letter-spacing:.04em;}
.aurs-fb:hover,.aurs-fb.on{border-color:#00e5c8;color:#00e5c8;background:rgba(0,229,200,.05);}
.aurs-sort-sep{margin-left:auto;display:flex;gap:6px;align-items:center;}

/* ── Scrollable verified strip ── */
.aurs-verified-label{font-size:10px;letter-spacing:.16em;color:#666;margin-bottom:16px;text-transform:uppercase;}
.aurs-scroll-outer{position:relative;margin-bottom:48px;}
.aurs-scroll-track{display:flex;gap:14px;overflow-x:auto;padding-bottom:14px;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;scrollbar-width:thin;scrollbar-color:#7c3aed #0d0d10;}
.aurs-scroll-track::-webkit-scrollbar{height:4px;}
.aurs-scroll-track::-webkit-scrollbar-track{background:#0d0d10;border-radius:2px;}
.aurs-scroll-track::-webkit-scrollbar-thumb{background:linear-gradient(90deg,#00e5c8,#7c3aed);border-radius:2px;}
.aurs-vcard{min-width:280px;max-width:280px;background:#13131a;border:1px solid #222230;border-radius:14px;padding:22px;scroll-snap-align:start;flex-shrink:0;}
.aurs-vcard-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.aurs-vname{font-size:13px;font-weight:500;color:#d8d8e8;}
.aurs-vbadge{font-size:9px;color:#00e5c8;letter-spacing:.06em;margin-top:3px;display:flex;align-items:center;gap:4px;}
.aurs-vbadge::before{content:"✓";font-size:9px;}
.aurs-vsource{font-size:9px;color:#2e2e3e;background:#141418;padding:3px 8px;border-radius:4px;white-space:nowrap;}
.aurs-vstars{color:#f5b400;font-size:11px;letter-spacing:1px;margin-bottom:8px;}
.aurs-vbody{font-size:12px;color:#8a8a9a;line-height:1.65;font-weight:300;}
.aurs-scroll-arrows{display:flex;gap:8px;justify-content:flex-end;margin-top:10px;}
.aurs-arrow{width:32px;height:32px;border-radius:50%;border:1px solid #1e1e1e;background:transparent;color:#555;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .18s;}
.aurs-arrow:hover{border-color:#00e5c8;color:#00e5c8;}

/* ── Dynamic review grid ── */
.aurs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px;margin-bottom:40px;}
.aurs-card{background:#13131a;border:1px solid #1e1e2e;border-radius:14px;padding:24px;transition:border-color .2s,transform .2s;}
.aurs-card:hover{border-color:#252530;transform:translateY(-2px);}
.aurs-card-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;}
.aurs-cname{font-size:13px;font-weight:500;color:#d8d8e8;}
.aurs-cver{font-size:9px;color:#00e5c8;letter-spacing:.06em;margin-top:3px;opacity:.85;}
.aurs-cdate{font-size:10px;color:#4a4a60;}
.aurs-cstars{color:#f5b400;font-size:11px;letter-spacing:1px;margin-bottom:8px;}
.aurs-ctitle{font-size:14px;font-weight:500;color:#d8d8e8;margin:0 0 7px;line-height:1.3;}
.aurs-cbody{font-size:13px;color:#8a8a9a;line-height:1.7;font-weight:300;margin:0;}
.aurs-helpful{display:flex;align-items:center;gap:8px;margin-top:14px;padding-top:12px;border-top:1px solid #141418;}
.aurs-list{max-height:900px;overflow-y:auto;padding-right:8px;scrollbar-width:thin;}
.aurs-list::-webkit-scrollbar{width:6px;}
.aurs-list::-webkit-scrollbar-thumb{background:linear-gradient(180deg,#7c5cff,#2dd4bf);border-radius:999px;}

.aurs-hlbl{font-size:10px;color:#555;}
.aurs-hbtn{padding:3px 11px;border-radius:999px;border:1px solid #222232;background:transparent;color:#666;font-size:11px;cursor:pointer;font-family:inherit;transition:all .15s;}
.aurs-hbtn:hover{border-color:#252530;color:#666;}
.aurs-hbtn.voted{border-color:rgba(0,229,200,.3);color:#00e5c8;cursor:default;}
.aurs-nores{text-align:center;padding:56px 0;color:#2e2e3e;font-size:14px;}

/* ── Shopify contact form ── */
.aurs-form-section{max-width:580px;margin:0 auto;padding:40px;background:#0d0d10;border:1px solid #1a1a22;border-radius:20px;display:none;}
