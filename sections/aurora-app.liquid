{%- comment -%}
  AURORA — Companion App explainer.
  Upload your QRing/Colmi app screenshots in the theme editor (Phone 1/2/3 image settings).
  If an image is left empty, a styled fallback screen renders so the section never looks broken.
{%- endcomment -%}

<div class="aurapp" data-aurapp>
  <div class="aurapp-wrap">
    <div class="aurapp-intro">
      {%- if section.settings.eyebrow != blank -%}<span class="aurapp-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="aurapp-title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subtext != blank -%}<p class="aurapp-sub">{{ section.settings.subtext }}</p>{%- endif -%}
    </div>

    <div class="aurapp-grid">
      {%- for i in (1..3) -%}
        {%- liquid
          assign img = section.settings['image_' | append: i]
          assign t = section.settings['title_' | append: i]
          assign b = section.settings['text_' | append: i]
          assign stat = section.settings['stat_' | append: i]
          assign unit = section.settings['unit_' | append: i]
        -%}
        <div class="aurapp-card">
          <div class="aurapp-phone">
            <span class="aurapp-notch"></span>
            {%- if img != blank -%}
              <img src="{{ img | image_url: width: 640 }}" alt="{{ t | escape }}" width="320" height="680" loading="lazy">
            {%- else -%}
              <div class="aurapp-scr">
                <div class="aurapp-scr-lbl">{{ t }}</div>
                <div class="aurapp-scr-big">{{ stat }}<em>{{ unit }}</em></div>
                <div class="aurapp-spark" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div>
              </div>
            {%- endif -%}
          </div>
          <div class="aurapp-meta">
            {%- if t != blank -%}<div class="aurapp-h">{{ t }}</div>{%- endif -%}
            {%- if b != blank -%}<p>{{ b }}</p>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .aurapp{background:#080808;padding:84px 24px;border-top:1px solid #1e1e1e;}
  .aurapp-wrap{max-width:1040px;margin:0 auto;}
  .aurapp-intro{text-align:center;max-width:620px;margin:0 auto 56px;}
  .aurapp-eyebrow{display:inline-block;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:11px;letter-spacing:.24em;color:#00e5c8;margin-bottom:16px;}
  .aurapp-title{font-size:clamp(24px,3.2vw,38px);font-weight:300;color:#fff;margin:0 0 14px;line-height:1.1;letter-spacing:-.01em;}
  .aurapp-sub{color:#8d8d97;font-size:14px;line-height:1.65;margin:0;}
  .aurapp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;}
  .aurapp-card{display:flex;flex-direction:column;}
  .aurapp-phone{position:relative;aspect-ratio:9/19;border-radius:30px;background:linear-gradient(180deg,#101015,#0a0a0d);border:1px solid rgba(255,255,255,.09);box-shadow:inset 0 1px 0 rgba(255,255,255,.06),0 40px 70px -34px rgba(0,0,0,.95);overflow:hidden;transition:transform .5s cubic-bezier(.16,1,.3,1),box-shadow .5s;}
  .aurapp-card:hover .aurapp-phone{transform:translateY(-6px);box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 50px 90px -34px rgba(0,0,0,.98),0 0 52px -16px rgba(0,229,200,.25);}
  .aurapp-phone img{width:100%;height:100%;object-fit:cover;display:block;}
  .aurapp-notch{position:absolute;top:11px;left:50%;transform:translateX(-50%);width:58px;height:5px;border-radius:3px;background:rgba(255,255,255,.14);z-index:2;}
  .aurapp-scr{height:100%;padding:38px 20px 22px;display:flex;flex-direction:column;justify-content:center;gap:10px;}
  .aurapp-scr-lbl{font-size:10px;letter-spacing:.18em;color:#6a6a80;text-transform:uppercase;}
  .aurapp-scr-big{font-size:clamp(34px,6vw,52px);font-weight:300;color:#fff;line-height:1;}
  .aurapp-scr-big em{font-style:normal;font-size:15px;color:#8d8d97;margin-left:5px;}
  .aurapp-spark{display:flex;align-items:flex-end;gap:5px;height:46px;margin-top:8px;}
  .aurapp-spark i{flex:1;border-radius:2px;background:linear-gradient(180deg,#00e5c8,#0f9b8a);opacity:.9;}
  .aurapp-spark i:nth-child(1){height:38%}.aurapp-spark i:nth-child(2){height:64%}.aurapp-spark i:nth-child(3){height:48%}.aurapp-spark i:nth-child(4){height:88%}.aurapp-spark i:nth-child(5){height:58%}.aurapp-spark i:nth-child(6){height:76%}.aurapp-spark i:nth-child(7){height:44%}
  .aurapp-meta{margin-top:22px;}
  .aurapp-h{color:#fff;font-size:15px;font-weight:500;margin-bottom:7px;}
  .aurapp-meta p{color:#8d8d97;font-size:13px;line-height:1.6;margin:0;}
  .aurapp.aurapp-js .aurapp-card{opacity:0;transform:translateY(26px);transition:opacity .7s cubic-bezier(.16,1,.3,1),transform .7s cubic-bezier(.16,1,.3,1);}
  .aurapp.aurapp-js.in .aurapp-card{opacity:1;transform:none;}
  .aurapp.aurapp-js.in .aurapp-card:nth-child(2){transition-delay:.1s}
  .aurapp.aurapp-js.in .aurapp-card:nth-child(3){transition-delay:.2s}
  @media(max-width:760px){.aurapp-grid{grid-template-columns:1fr;max-width:340px;margin:0 auto;}}
  @media (prefers-reduced-motion:reduce){.aurapp.aurapp-js .aurapp-card{opacity:1 !important;transform:none !important;transition:none !important;}}
</style>

<script>
(function(){
  var secs=document.querySelectorAll('.aurapp:not([data-aurapp-init])');
  if(!secs.length) return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  for(var k=0;k<secs.length;k++){(function(sec){
    sec.setAttribute('data-aurapp-init','1');
    if(reduce||!('IntersectionObserver' in window)) return;
    sec.classList.add('aurapp-js');
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}});},{threshold:.16,rootMargin:'0px 0px -8% 0px'});
    io.observe(sec);
  })(secs[k]);}
})();
</script>

{% schema %}
{
  "name": "Companion App",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "THE COMPANION APP" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your body, beautifully decoded." },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "AURORA pairs with the free QRing app over Bluetooth. Wear the ring around the clock — it tracks on-device, then syncs your full history the moment you open the app. No subscription, no gated features." },
    { "type": "header", "content": "Screen 1" },
    { "type": "image_picker", "id": "image_1", "label": "Phone 1 screenshot" },
    { "type": "text", "id": "title_1", "label": "Title", "default": "Continuous heart rate" },
    { "type": "textarea", "id": "text_1", "label": "Text", "default": "24/7 heart-rate tracking with daily trends and resting-rate insight." },
    { "type": "text", "id": "stat_1", "label": "Fallback stat", "default": "123" },
    { "type": "text", "id": "unit_1", "label": "Fallback unit", "default": "BPM" },
    { "type": "header", "content": "Screen 2" },
    { "type": "image_picker", "id": "image_2", "label": "Phone 2 screenshot" },
    { "type": "text", "id": "title_2", "label": "Title", "default": "Your daily dashboard" },
    { "type": "textarea", "id": "text_2", "label": "Text", "default": "Steps, sleep stages, stress and blood oxygen — one clean view, updated as you move." },
    { "type": "text", "id": "stat_2", "label": "Fallback stat", "default": "32,768" },
    { "type": "text", "id": "unit_2", "label": "Fallback unit", "default": "steps" },
    { "type": "header", "content": "Screen 3" },
    { "type": "image_picker", "id": "image_3", "label": "Phone 3 screenshot" },
    { "type": "text", "id": "title_3", "label": "Title", "default": "Blood oxygen (SpO₂)" },
    { "type": "textarea", "id": "text_3", "label": "Text", "default": "Overnight SpO₂ monitoring to understand recovery and breathing quality." },
    { "type": "text", "id": "stat_3", "label": "Fallback stat", "default": "98" },
    { "type": "text", "id": "unit_3", "label": "Fallback unit", "default": "%" }
  ],
  "presets": [{ "name": "Companion App" }]
}
{% endschema %}
